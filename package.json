{
  "name": "nju-class-cf",
  "version": "1.0.0",
  "private": true,
  "license": "GPL-3.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "postdeploy": "curl -fsS -X POST -H \"Authorization: Bearer $DEPLOY_REFRESH_TOKEN\" \"$WORKER_URL/__refresh\"",
    "schema:local": "wrangler d1 execute nju-class --local --file=./schema.sql",
    "schema:remote": "wrangler d1 execute nju-class --remote --file=./schema.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pinyin-pro": "^3.26.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240909.0",
    "typescript": "^5.5.0",
    "wrangler": "^3.78.0"
  }
}
